.ds-node__event-inspector{
    background-color: #3F3F3F;
    margin-top: 30px;
    margin-bottom: 30px;
    min-height: 95%;
    min-width: 30%;
    max-width: 30%;
    align-self: flex-end;
    border-radius: 5px;
    padding: 15px;
}

.ds-node__extension-container{
    background-color: #1D1D1E;
    padding: 8px;
}

.ds-node__main-container{
    background-color: #1D1D1E;
}

.ds-node__custom-data-container{
    background-color: #212325;
    border-radius: 4px;
    padding: 8px;
}

.ds-node__label{
    border-radius: 4px;
    max-width: 240px;
    min-width: 160px;
    padding: 8px;
}

.ds-node__startnode{
    background-color: #7F7;
}

.ds-node__endnode{
    background-color: #F77;
}

.ds-node__eventnode{
    background-color: #F7F;
}

.ds-node__pausenode{
    background-color: #FF7;
}

.ds-node__conditionnode{
    background-color: #7FF;
}

.ds-node__textfield {
    max-width: 100%;
}

.ds-node__textfield > .unity-text-field__input{
    background-color: #1D1D1E;
    border-color: #27292C;
    border-radius: 4px;
    padding: 8px;
}

.ds-node__textfield__hidden > .unity-text-field__input{
    background-color: transparent;
    border-color: transparent;
}

.ds-node__textfield__hidden > .unity-text-field__input:hover{
    background-color: #4A4B4C;
}

.ds-node__textfield__hidden > .unity-text-field__input:focus{
    background-color: #1D1D1E;
    border-color: #27292C;
}

.ds-node__filename-textfield > .unity-text-field__input{
    max-width: 1000px;
}

.ds-node__filename-textfield > .unity-text-field__input:focus{
    margin: 4px;
    padding: 4px;
}

.ds-node__choice-textfield > .unity-text-field__input{
    font-size: 11px;
    height: 35px;
    max-width: 1000px;
    min-width: 0px;
}

.ds-node__choice-textfield > .unity-text-field__input:focus{
    height: 25px;
    margin: 4px;
    padding: 4px;
}

.ds-node__quote-textfield > .unity-text-field__input{
    background-color: #232527;
    border-color: transparent;
    border-left-color: #27292C;
    border-left-width: 4px;
    padding: 16px;
    max-width: 600px;
}

.ds-node__quote-textfield > .unity-text-field__input:hover{
    background-color: #252729;
}

.ds-node__quote-textfield > .unity-text-field__input:focus{
    background-color: #1D1D1E;
    border-color: #27292C;
}

.ds-node__button{
    background-color: #252729;
    border-color: #1D1D1E;
    margin: 4px;
    max-height: 25px;
}

.ds-node__button:hover{
    background-color: #2B2D2F;
}

.ds-node__button:active{
    background-color: #212325;
    color: #FDD057;
}

.ds-node__custom-data-container > Foldout{
    margin-left: -4px;
    margin-top: 4px;
}

.ds-node__custom-data-container > Foldout > TextField{
    margin-left: -12px;
    margin-top: 8px;
}

TextField{
    margin-left: 0px;
}

.unity-toggle__text{
    margin-left: 2px;
}